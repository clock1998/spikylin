@using Spikylin.Model
@model IEnumerable<Post>

@if (Model.Any())
{
    <div class="grid gap-4 lg:grid-cols-2">
        @foreach (var doc in Model)
        {
            <a asp-page="/Post/Post" asp-route-fileName="@doc.FileName" class="card border border-base-300 bg-base-100 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
                <div class="card-body gap-4">
                    <div class="flex flex-wrap items-center gap-2 text-sm text-base-content/60">
                        <span class="badge badge-outline">Featured</span>
                        <span>@doc.Markdown.Meta.Date.ToString("yyyy-MM-dd")</span>
                    </div>
                    <div class="space-y-2">
                        <h3 class="text-xl font-semibold text-base-content">@doc.Markdown.Meta.Title</h3>
                        <p class="line-clamp-3 text-sm leading-6 text-base-content/75">@doc.Markdown.Meta.Description</p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var tag in doc.Markdown.Meta.Tags)
                        {
                            <span class="badge badge-soft">&num;@tag</span>
                        }
                    </div>
                </div>
            </a>
        }
    </div>
}
else
{
    <div class="rounded-box border border-dashed border-base-300 bg-base-100 p-6 text-sm text-base-content/70">
        No featured posts yet.
    </div>
}
